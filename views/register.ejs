<%- include('partials/nav-no-navigation.ejs') %>

<!--TODO: Melhorar a interface de
erro, para não ser apenas um texto, mas sim um card bonito a informar o
utilizador do erro e como resolver, e também adicionar uma animação hover para
dar um toque mais interativo.-->
<div class="divider-froms" style="height: 10dvh"></div>
<div class="container d-flex align-items-center justify-content-center h-100">
  <div class="modal-dialog">
    <div
      class="modal-content d-flex align-items-center justify-content-around"
      style="background-color: #fbfbfb"
    >
      <div class="d-block align-self-end m-5 pe-4 border-bottom-0">
        <a class="btn-close ms-5" href="/" aria-label="Close">
          <i class="bi bi-x"></i>
        </a>
      </div>
      <div class="modal-header p-1 pb-3 border-bottom-0">
        <h1 class="fw-bold mb-5 fs-3">You can create your account</h1>
      </div>
      <div class="modal-body p-5 pt-0">
        <form
          class="form-control register-user p-4"
          action="/register"
          method="POST"
        >
          <div class="form-floating mb-3">
            <input
              name="username"
              type="text"
              class="form-control rounded-3 users-username-input"
              id="usernameInput"
              placeholder="name@example.com"
            />
            <label for="usernameInput">User</label>
            <small
              id="usernameError"
              class="text-danger d-none mt-2"
              style="display: block; font-size: 0.875rem"
            >
              ❌ Username já registado
            </small>
          </div>
          <div class="form-floating mb-3">
            <input
              name="email"
              type="email"
              class="form-control rounded-3 users-email-input"
              id="emailInput"
              placeholder="Please enter your email"
            />
            <label for="emailInput">Email </label>
            <small
              id="emailError"
              class="text-danger d-none mt-2"
              style="display: block; font-size: 0.875rem"
            >
              ❌ Email já registado
            </small>
          </div>
          <div class="form-floating mb-3">
            <input
              name="password"
              type="password"
              class="form-control rounded-3"
              id="floatingPassword"
              placeholder="Password"
            />
            <label for="floatingPassword">Password</label>
            <small
              id="passwordError"
              class="text-danger d-none mt-2"
              style="display: block; font-size: 0.875rem"
            >
              ❌ Password inválida
            </small>
            <kpm-field-badge
              style="--FieldBadge-ZLevel: 1057 !important"
              type="default"
              loading="false"
              menu-type="password"
              class="kpm_input-field-button kpm_gray-key-icon"
              data-product-type="b2c"
            ></kpm-field-badge>
          </div>
          <div class="form-floating mb-3">
            <input
              name="confirmPassword"
              type="password"
              class="form-control rounded-3 confirm-password-input"
              id="floatingConfirmPassword"
              placeholder="Confirm Password"
            />
            <label for="floatingConfirmPassword">Confirm Password</label>
            <small
              id="confirmPasswordError"
              class="text-danger d-none mt-2"
              style="display: block; font-size: 0.875rem"
            >
              ❌ Password não corresponde
            </small>
            <kpm-field-badge
              style="--FieldBadge-ZLevel: 1057 !important"
              type="default"
              loading="false"
              menu-type="password"
              class="kpm_input-field-button kpm_gray-key-icon card-confirm-password"
              data-product-type="b2c"
            ></kpm-field-badge>
          </div>
          <button
            class="w-100 mb-2 btn btn-lg rounded-3 btn-primary"
            type="submit"
          >
            Sign up
          </button>
          <div
            class="d-flex justify-content-center align-items-center mb-3 mt-4"
          >
            <div class="form-check">
              <input
                class="form-check-input"
                type="checkbox"
                value=""
                id="rememberMeCheck"
              />
              <label class="form-check-label" for="rememberMeCheck">
                I agree to the
                <a href="#" class="text-decoration-none ms-1">terms of use</a>
              </label>
            </div>
          </div>
          <div class="d-flex mb-3">
            <hr class="mt-3 flex-fill" style="text-decoration: dashed" />
            <h5 class="mx-4 mt-1">or</h5>
            <hr class="mt-3 flex-fill" style="text-decoration: dashed" />
          </div>
          <button
            class="w-100 py-2 mb-2 btn btn-light text-black rounded-3"
            style="border: 1px solid #c9c9c9; background-color: #fff"
            type="submit"
          >
            <svg class="bi me-2" width="16" height="16" aria-hidden="true">
              <i class="bi bi-google"></i>
            </svg>
            Google
          </button>
          <button
            class="w-100 py-2 mb-2 btn btn-outline-primary rounded-3 text-primary"
            style="border: 1px solid #c9c9c9; background-color: #fff"
            type="submit"
          >
            <svg class="bi ms-4" width="16" height="16" aria-hidden="true">
              <i class="bi bi-facebook"></i>
            </svg>
            Facebook
          </button>
          <button
            class="w-100 py-2 mb-2 btn btn-outline-black rounded-3 text-black"
            style="border: 1px solid #c9c9c9; background-color: #fff"
            type="submit"
          >
            <svg class="bi m-0" width="16" height="16" aria-hidden="true">
              <i class="bi bi-apple"></i>
            </svg>
            Apple
          </button>
          <div class="d-block align-self-end m-3 pe-3 border-top-0">
            <p class="text-center">
              Already have an account?
              <a href="/login" class="text-decoration-none">Sign in</a>
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer-no-navigation.ejs') %>

<!-- Script para validação de username em tempo real -->

<script>
  //TODO: Modificar os alertas para serem mais bonitos e informativos, em vez de simples pop-ups, criar um card de alerta que apareça abaixo do formulário com a mensagem de erro e dicas para resolver, e adicionar uma animação hover para dar um toque mais interativo.
  //TODO: Passar a codigo para um ficheiro JS externo para manter o código mais organizado e limpo, e facilitar a manutenção futura.
  const usernameInput = document.getElementById('usernameInput');
  const usernameError = document.getElementById('usernameError');
  const emailInput = document.getElementById('emailInput');
  const emailError = document.getElementById('emailError');
  const passwordInput = document.getElementById('floatingPassword');
  const passwordError = document.getElementById('passwordError');
  const confirmPasswordInput = document.getElementById(
    'floatingConfirmPassword'
  );
  const confirmPasswordError = document.getElementById('confirmPasswordError');
  const form = document.querySelector('.register-user');

  let usernameCheckTimeout;
  let emailCheckTimeout;
  let usersCache = null;

  // Cache de utilizadores para reduzir requisições
  async function getUsers() {
    if (!usersCache) {
      try {
        const response = await fetch('/users');
        usersCache = await response.json();
      } catch (error) {
        console.error('Erro ao carregar utilizadores:', error);
        return [];
      }
    }
    return usersCache;
  }

  // Função genérica para validar disponibilidade
  async function checkAvailability(input, error, field, compareKey) {
    const value = input.value.trim();

    if (!value) {
      clearFieldStyling(input, error);
      return;
    }

    const users = await getUsers();
    const exists = users.some(
      (user) => user[compareKey].toLowerCase() === value.toLowerCase()
    );

    if (exists) {
      input.style.borderColor = '#dc3545';
      input.style.borderWidth = '2px';
      error.classList.remove('d-none');
    } else {
      input.style.borderColor = '#198754';
      input.style.borderWidth = '2px';
      error.classList.add('d-none');
    }
  }

  // Limpar styling do campo
  function clearFieldStyling(input, error) {
    input.style.borderColor = '';
    input.style.borderWidth = '';
    error.classList.add('d-none');
  }

  // Configurar event listeners com debounce
  const setupInputListener = (input, error, checkFunction, timeoutVar) => {
    input.addEventListener('blur', checkFunction);
    input.addEventListener('input', () => {
      clearTimeout(timeoutVar);
      timeoutVar = setTimeout(checkFunction, 500);
    });
  };

  // Verificar username em tempo real
  usernameInput.addEventListener('blur', () =>
    checkAvailability(usernameInput, usernameError, 'username', 'username')
  );
  usernameInput.addEventListener('input', () => {
    clearTimeout(usernameCheckTimeout);
    usernameCheckTimeout = setTimeout(() => {
      if (usernameInput.value.trim().length > 0) {
        checkAvailability(usernameInput, usernameError, 'username', 'username');
      } else {
        clearFieldStyling(usernameInput, usernameError);
      }
    }, 500);
  });

  // Verificar email em tempo real
  emailInput.addEventListener('blur', () =>
    checkAvailability(emailInput, emailError, 'email', 'email')
  );
  emailInput.addEventListener('input', () => {
    clearTimeout(emailCheckTimeout);
    emailCheckTimeout = setTimeout(() => {
      if (emailInput.value.trim().length > 0) {
        checkAvailability(emailInput, emailError, 'email', 'email');
      } else {
        clearFieldStyling(emailInput, emailError);
      }
    }, 500);
  });

  // Verificar passwords em tempo real
  function checkPasswordsMatch() {
    const password = passwordInput.value;
    const confirmPassword = confirmPasswordInput.value;

    if (!password || !confirmPassword) {
      // Se alguma está vazia, limpar styling
      if (!password) {
        passwordInput.style.borderColor = '';
        passwordInput.style.borderWidth = '';
      }
      if (!confirmPassword) {
        confirmPasswordInput.style.borderColor = '';
        confirmPasswordInput.style.borderWidth = '';
      }
      confirmPasswordError.classList.add('d-none');
      return;
    }

    if (password === confirmPassword) {
      // Passwords são iguais - mudar para verde
      passwordInput.style.borderColor = '#198754';
      passwordInput.style.borderWidth = '2px';
      confirmPasswordInput.style.borderColor = '#198754';
      confirmPasswordInput.style.borderWidth = '2px';
      confirmPasswordError.classList.add('d-none');
    } else {
      // Passwords são diferentes - mudar para vermelho
      passwordInput.style.borderColor = '#dc3545';
      passwordInput.style.borderWidth = '2px';
      confirmPasswordInput.style.borderColor = '#dc3545';
      confirmPasswordInput.style.borderWidth = '2px';
      confirmPasswordError.classList.remove('d-none');
      confirmPasswordError.textContent = '❌ As passwords não correspondem';
    }
  }

  passwordInput.addEventListener('input', checkPasswordsMatch);
  confirmPasswordInput.addEventListener('input', checkPasswordsMatch);

  // Quando o formulário for submetido
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Recolher dados do formulário
      const formData = {
        username: document.querySelector('input[name="username"]').value,
        email: document.querySelector('input[name="email"]').value,
        password: document.querySelector('input[name="password"]').value,
        confirmPassword: document.querySelector('input[name="confirmPassword"]')
          .value,
      };

      // Validar se username está vazio
      if (!formData.username.trim()) {
        usernameInput.style.borderColor = '#dc3545';
        usernameInput.style.borderWidth = '2px';
        usernameError.classList.remove('d-none');
        usernameError.textContent = 'O username é obrigatório';
        // alert('❌ O username é obrigatório');
        return;
      }

      if (!formData.email.trim()) {
        emailInput.style.borderColor = '#dc3545';
        emailInput.style.borderWidth = '2px';
        emailError.classList.remove('d-none');
        emailError.textContent = 'O email é obrigatório';
        // alert('❌ O email é obrigatório');
        return;
      }

      if (!formData.password.trim()) {
        passwordInput.style.borderColor = '#dc3545';
        passwordInput.style.borderWidth = '2px';
        passwordError.classList.remove('d-none');
        passwordError.textContent = '❌ A password é obrigatória';
        // alert('❌ A password é obrigatória');
        return;
      }

      if (!formData.confirmPassword.trim()) {
        confirmPasswordInput.style.borderColor = '#dc3545';
        confirmPasswordInput.style.borderWidth = '2px';
        confirmPasswordError.classList.remove('d-none');
        confirmPasswordError.textContent = '❌ A confirmação da password é obrigatória';
        // alert('❌ A confirmação da password é obrigatória');
        return;
      }

      if (formData.password !== formData.confirmPassword) {
        passwordInput.style.borderColor = '#dc3545';
        passwordInput.style.borderWidth = '2px';
        confirmPasswordInput.style.borderColor = '#dc3545';
        confirmPasswordInput.style.borderWidth = '2px';
        confirmPasswordError.classList.remove('d-none');
        confirmPasswordError.textContent = '❌ As passwords não correspondem';
        // alert('❌ As passwords não correspondem');
        return;
        
      } else {
        passwordInput.style.borderColor = '#198754';
        passwordInput.style.borderWidth = '2px';
        confirmPasswordInput.style.borderColor = '#198754';
        confirmPasswordInput.style.borderWidth = '2px';
        confirmPasswordError.classList.add('d-none');
      }

      // Forçar validação final antes de submeter
      await checkAvailability(
        usernameInput,
        usernameError,
        'username',
        'username'
      );

      await checkAvailability(emailInput, emailError, 'email', 'email');

      // Verificar se tem erros antes de enviar
      if (
        !usernameError.classList.contains('d-none') ||
        usernameInput.style.borderColor === 'rgb(220, 53, 69)' ||
        usernameInput.style.borderColor === '#dc3545'
      ) {
        checkAvailability(usernameInput, usernameError, 'username', 'username');
        return;
      }

      if (
        !emailError.classList.contains('d-none') ||
        emailInput.style.borderColor === 'rgb(220, 53, 69)' ||
        emailInput.style.borderColor === '#dc3545'
      ) {
        checkAvailability(emailInput, emailError, 'email', 'email');
        return;
      }

      try {
        const response = await fetch('/register', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formData),
        });

        const data = await response.json();

        if (!response.ok) {
          alert('❌ Erro: ' + data.message);
        } else {
          // Sucesso no registo
          sessionStorage.setItem('userCreatedSuccess', 'true');
          console.log('✅ Utilizador criado com sucesso');
          //alert('✅ Utilizador criado com sucesso!');
          window.location.href = '/';
        }
      } catch (error) {
        console.error('Erro ao enviar formulário:', error);
        alert('❌ Erro na comunicação com o servidor');
      }
    });
  }
</script>
