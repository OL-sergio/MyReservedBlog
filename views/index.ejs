<%- include('partials/header.ejs') %>

<!-- Hero section -->
<div class="container background-container">
  <div class="row flex-row-reverse align-items-center g-5 py-5">
    <div class="col-10 col-sm-8 col-lg-6">
      <img
        src="/images/image_2_coding.jpg"
        class="d-block mx-lg-auto hero-image"
        loading="lazy"
      />
    </div>
    <div class="col-lg-6">
      <h1
        class="display-5 fw-bold align-items-center text-start lh-1 mx-5 px-4 mb-4"
      >
        How to be a better developer in 2026
      </h1>
      <div class="card-body mb-3 text-start mx-5 px-4">
        <p
          class="card-text text-body-secondary paragraph-truncate"
          id="card-hero-text"
        >
          In 2026, being a better developer involves continuous learning,
          embracing new technologies, and honing problem-solving skills. Stay
          updated with industry trends, collaborate with peers, and focus on
          writing clean, efficient code. Additionally, prioritize soft skills
          like communication and adaptability to thrive in the ever-evolving
          tech landscape.
        </p>
        <div
          class="d-flex flex-row-reverse justify-content-between align-items-center pt-5 mt-4"
        >
          <button
            type="button"
            class="read-more-btn text-decoration-none text-black fw-bolder"
            id="card-hero-btn"
          >
            Read more
          </button>

          <h6 class="text-body-secondary">2025 nov 12</h6>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Hero section -->
<div class="divider"></div>

