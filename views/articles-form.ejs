<% if (typeof isAuthenticated !== 'undefined' && isAuthenticated && user) { %>
<%- include('partials/nav-registered-user.ejs', { user: user }) %> <% } else {
%> <%- include('partials/navigation.ejs') %> <% } %>

<!-- 
//TODO: Add edit page and delete page for articles, and add the links to the articles page.
//https://quilljs.com/docs/quickstart
//https://cdn.ckeditor.com
-->

<div class="container">
  <div class="d-flex justify-content-center align-items-center">
    <h3><%= article ? 'Edit your article' : 'Add your article' %></h3>
  </div>

  <div
    id="message-container-created-article"
    class="container mt-3"
    style="display: none"
    data-show="<%= successMessage ? 'true' : 'false' %>"
  >
    <div
      class="alert alert-success alert-dismissible fade show"
      role="alert"
      id="success-message-created-article"
    >
      <strong>Success!</strong> <%= successMessage %>
      <button
        type="button"
        class="btn-close close-message-created-article"
        data-bs-dismiss="alert"
        aria-label="Close"
      ></button>
    </div>
  </div>

  <form id="article-form" class="mt-3" method="POST" action="/articles-form">
    <header class="d-flex justify-content-end py-3">
      <div class="btn-group me-4" role="group" aria-label="First group">
        <button class="btn btn-success" type="submit">Save article</button>
        <button class="btn btn-primary" type="button" id="btn-preview">
          Preview
        </button>
      </div>
    </header>

    <div class="mb-3 me-4 ms-4">
      <label class="form-label" for="title">Title</label>
      <input
        id="title"
        name="title"
        value="<%= article ? article.title : '' %>"
        type="text"
        class="form-control"
        placeholder="Write an article title"
        required
      />
    </div>

    <div class="mb-3 me-4 ms-4">
      <label class="form-label" for="excerpt">Excerpt (optional)</label>
      <textarea
        id="excerpt"
        name="excerpt"
        class="form-control"
        rows="2"
        placeholder="Short summary"
      >
    <%= article ? article.excerpt : '' %> </textarea>

    </div>

    <div class="mb-3 me-4 ms-4 d-flex align-items-center gap-3">
      <label class="mb-0" for="published">Publish now</label>
      <input id="published" name="published" type="checkbox" value="true" <%= article && article.published ? 'checked' : '' %> />
    
    </div>

    <input
      id="articleId"
      name="id"
      type="hidden"
      value="<%= article ? article.id : '' %>"
    />
    <input id="content" name="content" type="hidden" />
    <input id="tags" name="tags" type="hidden" value="[]" />

    <div id="toolbar-container" class="me-4 ms-4">
      <span class="ql-formats">
        <select class="ql-font"></select>
        <select class="ql-size"></select>
      </span>
      <span class="ql-formats">
        <button class="ql-bold"></button>
        <button class="ql-italic"></button>
        <button class="ql-underline"></button>
        <button class="ql-strike"></button>
      </span>
      <span class="ql-formats">
        <select class="ql-color"></select>
        <select class="ql-background"></select>
      </span>
      <span class="ql-formats">
        <button class="ql-script" value="sub"></button>
        <button class="ql-script" value="super"></button>
      </span>
      <span class="ql-formats">
        <button class="ql-header" value="1"></button>
        <button class="ql-header" value="2"></button>
        <button class="ql-blockquote"></button>
        <button class="ql-code-block"></button>
      </span>
      <span class="ql-formats">
        <button class="ql-list" value="ordered"></button>
        <button class="ql-list" value="bullet"></button>
        <button class="ql-indent" value="-1"></button>
        <button class="ql-indent" value="+1"></button>
      </span>
      <span class="ql-formats">
        <button class="ql-direction" value="rtl"></button>
        <select class="ql-align"></select>
      </span>
      <span class="ql-formats">
        <button class="ql-link"></button>
        <button class="ql-image"></button>
        <button class="ql-video"></button>
        <button class="ql-formula"></button>
      </span>
      <span class="ql-formats">
        <button class="ql-clean"></button>
      </span>
    </div>

    <div id="editor" class="editorText mb-5 me-4 ms-4"></div>
  </form>
</div>

<%- include('partials/footer.ejs') %>

<!-- Initialize Quill editor -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const successContainer = document.getElementById(
      'message-container-created-article'
    );
    if (successContainer && successContainer.dataset.show === 'true') {
      successContainer.style.display = 'block';
      const timer = window.setTimeout(() => {
        successContainer.style.display = 'none';
      }, 5000);

      const closeButton = successContainer.querySelector(
        '.close-message-created-article'
      );
      closeButton?.addEventListener('click', () => {
        window.clearTimeout(timer);
        successContainer.style.display = 'none';
      });
    }
  });

  const quill = new Quill('#editor', {
    theme: 'snow',
    modules: { toolbar: '#toolbar-container' },
    placeholder: 'Compose an epic text...',
  });

  quill.root.innerHTML = `<%- article ? article.content : '' %>`;

  const form = document.getElementById('article-form');
  const contentInput = document.getElementById('content');
  form?.addEventListener('submit', () => {
    contentInput.value = quill.root.innerHTML;
  });

  document.getElementById('btn-preview')?.addEventListener('click', (e) => {
    e.preventDefault();

    const html = quill.root.innerHTML;
    const title = document.getElementById('title')?.value || 'Preview';
    const win = window.open('', '_blank');
    if (!win) return;

    win.document.write(`
      <html>
        <head>
          <meta charset="utf-8" />
          <title>${title}</title>
        </head>
        <body style="font-family: Arial, sans-serif; padding: 24px; margin: 4rm;">
          <h1>${title}</h1>
          <div>${html}</div>
        </body>
      </html>
    `);
    win.document.close();
  });
</script>
