<!DOCTYPE html>
<!-- Header partial template for the blog -->
<html lang="en">
  <head>
    <!-- Meta tags for character encoding and responsive design -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
      crossorigin="anonymous"
    />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />
    <link rel="icon" type="image/x-icon" href="/images/logo-icon.png" />
    <!-- Custom stylesheets -->
    <link rel="stylesheet" href="/styles/content.css" />
    <link rel="stylesheet" href="/styles/layout.css" />
  </head>
  <div class="container">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
      <!-- Brand/Logo -->
      <a
        href="/"
        class="d-flex align-items-center mb-lg-0 link-body-emphasis text-decoration-none ms-5"
      >
        <img
          src="/images/logo_no_background.png"
          background="transparent"
          width="140"
          height="140"
          aria-label="false"
        />
      </a>
      <div class="d-flex flex-lg-grow-1 m-3 justify-content-end">
        <form
          class="d-flex"
          role="search"
          style="width: 200px; height: 40px; background: #fbfbfb"
        >
          <div class="input-group">
            <button
              class="btn btn-outline-secondary bg-white border-0"
              type="submit"
              id="search-button"
            >
              <i class="bi bi-search text-secondary" id="search-icon"></i>
            </button>
            <input
              type="search"
              class="form-control border-0"
              placeholder="Search..."
              aria-label="Search"
            />
          </div>
        </form>
      </div>
      <!-- Toggler for mobile -->
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Navbar items -->
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center gap-2">
          <!-- Social Media Icons -->
          <li class="m-0 p-0">
            <a href="/" class="nav-link link-secondary">Home</a>
          </li>
          <li>
            <a href="/articles" class="nav-link link-body-emphasis">Articles</a>
          </li>
          <li class="m-0 p-0">
            <a href="https://twitter.com" class="nav-link text-black">
              <svg class="bi" width="0" height="0" role="img" aria-label="Home">
                >
                <i class="bi bi-twitter-x"></i>
              </svg>
            </a>
          </li>

          <li class="m-0 p-0">
            <a href="https://linkedin.com" class="nav-link text-black">
              <svg class="bi" class="bi" width="0" height="0" role="img">
                <i class="bi bi-linkedin"></i>
              </svg>
            </a>
          </li>
          <li class="m-0 p-0">
            <a href="https://instagram.com" class="nav-link text-black">
              <svg class="bi" width="0" height="0" role="img">
                <i class="bi bi-instagram"></i>
              </svg>
            </a>
          </li>

          <!-- User Dropdown Menu with Image -->
          <li class="nav-item dropdown ms-2 me-5">
            <a
              class="nav-link dropdown-toggle d-flex align-items-center gap-2"
              href="#"
              role="button"
              id="navbarUserDropdown"
              data-bs-toggle="dropdown"
              aria-expanded="false"
              style="text-decoration: none"
            >
              <img
                src="/images/user-logo.png"
                alt="User Profile"
                width="36"
                height="36"
                class="rounded-circle border border-2"
                style="
                  object-fit: scale-down;
                  border-color: #000 !important;
                  cursor: pointer;
                "
              />
            </a>

            <!-- Dropdown Menu Items -->
            <ul
              class="dropdown-menu dropdown-menu-end shadow-lg"
              aria-labelledby="navbarUserDropdown"
              style="min-width: 280px"
            >
              <!-- User Profile Header -->
              <li
                class="dropdown-header d-flex align-items-center gap-3 py-3 border-bottom"
              >
                <img
                  src="/images/user-logo.png"
                  alt="User"
                  width="50"
                  height="50"
                  style="object-fit: scale-down; border-color: #000"
                  class="rounded-circle border border-2"
                />
                <div>
                  <h6 class="mb-0 fw-bold">John Doe</h6>
                  <small class="text-muted">john@example.com</small>
                </div>
              </li>

              <!-- User Menu Items -->
              <li>
                <a class="dropdown-item py-2" href="/my-profile"
                  ><i class="bi bi-person me-2"></i> My Profile</a
                >
              </li>
              <li>
                <a class="dropdown-item py-2" href="/my-articles"
                  ><i class="bi bi-file-earmark-text me-2"></i> My Articles</a
                >
              </li>
              <li>
                <a class="dropdown-item py-2" href="/articles-form"
                  ><i class="bi bi-pencil-square me-2"></i> Create Article</a
                >
              </li>

              <li><hr class="dropdown-divider my-2" /></li>

              <li>
                <a class="dropdown-item py-2" href="/settings"
                  ><i class="bi bi-gear me-2"></i> Settings</a
                >
              </li>
              <li>
                <a class="dropdown-item py-2" href="/preferences"
                  ><i class="bi bi-sliders me-2"></i> Preferences</a
                >
              </li>

              <li><hr class="dropdown-divider my-2" /></li>

              <!-- Logout -->
              <li>
                <a class="dropdown-item py-2 text-danger" href="/logout"
                  ><i class="bi bi-box-arrow-right me-2"></i> Sign Out</a
                >
              </li>
            </ul>
          </li>
        </ul>
      </div>
    </nav>
  </div>
  <!-- Navigation partial for registered/logged-in users -->

  <!-- Bootstrap 5 Bundle JS (includes Popper.js) -->

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</html>
