<% const updateMessage = typeof successMessage !== 'undefined' ? successMessage
: null; %> <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated &&
user) { %> <%- include('partials/nav-registered-user.ejs', { user: user }) %> <%
} else { %> <% } %>

<div class="container py-4">
  <div
    id="success-message-updated-article"
    class="container mt-3"
    style="display: none"
  >
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <strong>Success!</strong> Article updated successfully.
      <button
        type="button"
        class="btn-close close-message-updated-article"
        data-bs-dismiss="alert"
        aria-label="Close"
      ></button>
    </div>
  </div>

  <div
    id="success-message-deleted-article"
    class="container mt-3"
    style="display: none"
  >
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <strong>Success!</strong> Article deleted successfully.
      <button
        type="button"
        class="btn-close close-message-deleted-article"
        data-bs-dismiss="alert"
        aria-label="Close"
      ></button>
    </div>
  </div>

  <h1 class="mb-3 pb-3">Your Articles</h1>

  <% const myArticles = Array.isArray(articles) ? articles : []; %> <% if
  (myArticles.length > 0) { %>
  <div class="row g-3">
    <% myArticles.forEach((a) => { %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= a.title %></h5>
          <% if (a.excerpt) { %>
          <p class="card-text text-muted"><%= a.excerpt %></p>
          <% } %>

          <div class="mt-auto d-flex flex-column gap-2">
            <small class="text-muted">
              <%= a.published ? 'Published' : 'Draft' %>
            </small>
            <small class="text-muted">
              <%= a.createdAt ? new Date(a.createdAt).toLocaleDateString() : ''
              %>
            </small>
            <a
              class="btn btn-primary"
              href="/view-article/<%= a.id ?? a._id %>"
              role="button"
              onclick="
                window.dispatchEvent(
                  new CustomEvent('view-article', {
                    detail: { id: '<%= a.id ?? a._id %>' },
                  })
                )
              "
            >
              Read
            </a>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <p class="text-muted">No articles yet.</p>
  <% } %>
</div>

<%- include('partials/footer.ejs') %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (sessionStorage.getItem('deleteArticleSuccess')) {
      // Mostrar o alerta de sucesso
      const successContainer = document.getElementById(
        'success-message-deleted-article'
      );
      if (!successContainer) return;

      successContainer.style.display = 'block';

      // Remover a mensagem automaticamente após 5 segundos
      setTimeout(() => {
        sessionStorage.removeItem('deleteArticleSuccess');
        successContainer.style.display = 'none';
      }, 5000);

      // Adicionar evento de clique ao botão de fechar
      const closeButton = successContainer.querySelector(
        '.close-message-deleted-article'
      );
      if (closeButton) {
        closeButton.addEventListener('click', () => {
          sessionStorage.removeItem('deleteArticleSuccess');
          successContainer.style.display = 'none';
        });
      }
    }
  });

  document.addEventListener('DOMContentLoaded', () => {
    if (sessionStorage.getItem('updateArticleSuccess')) {
      // Mostrar o alerta de sucesso
      const successContainer = document.getElementById(
        'success-message-updated-article'
      );
      if (!successContainer) return;

      successContainer.style.display = 'block';

      // Remover a mensagem automaticamente após 5 segundos
      setTimeout(() => {
        sessionStorage.removeItem('updateArticleSuccess');
        successContainer.style.display = 'none';
      }, 5000);

      // Adicionar evento de clique ao botão de fechar
      const closeButton = successContainer.querySelector(
        '.close-message-updated-article'
      );
      if (closeButton) {
        closeButton.addEventListener('click', () => {
          sessionStorage.removeItem('updateArticleSuccess');
          successContainer.style.display = 'none';
        });
      }
    }
  });
</script>
