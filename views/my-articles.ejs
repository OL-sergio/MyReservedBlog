<% if (typeof isAuthenticated !== 'undefined' && isAuthenticated && user) { %>
<%- include('partials/nav-registered-user.ejs', { user: user }) %> <% } else {
%> <%- include('partials/navigation.ejs') %> <% } %>

<div class="container py-4">
  <h1 class="mb-3">Your Articles</h1>

  <% const myArticles = Array.isArray(articles) ? articles : []; %> <% if
  (myArticles.length > 0) { %>
  <div class="row g-3">
    <% myArticles.forEach((a) => { %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= a.title %></h5>
          <% if (a.excerpt) { %>
          <p class="card-text text-muted"><%= a.excerpt %></p>
          <% } %>

          <div class="mt-auto d-flex flex-column gap-2">
            <small class="text-muted">
              <%= a.published ? 'Published' : 'Draft' %>
            </small>
            <small class="text-muted">
              <%= a.createdAt ? new Date(a.createdAt).toLocaleDateString() : ''
              %>
            </small>
            <a
              class="btn btn-primary"
              href="#"
              role="button"
              onclick="
                window.dispatchEvent(
                  new CustomEvent('open-article', {
                    detail: { id: '<%= a.id ?? a._id %>' },
                  })
                )
              "
            >
              Read
            </a>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <p class="text-muted">No articles yet.</p>
  <% } %>
</div>

<%- include('partials/footer.ejs') %>
